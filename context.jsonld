{
  "@context": {
    "schema": "https://schema.org/",
    "wd": "http://www.wikidata.org/entity/",
    
    "@vocab": "https://schema.org/",
    
    "identifier": "@id",
    "type": "@type",
    
    "entropy": "schema:value",
    "protocol": "schema:CreativeWork",
    "induction": "schema:target",

    "color": "schema:color",

    "geo": "schema:geo",
    "lat": "schema:latitude",
    "lon": "schema:longitude",

    "wiki": { "@id": "schema:usageInfo", "@type": "@id" },
    "repo": { "@id": "schema:codeRepository", "@type": "@id" },
    "gallery": { "@id": "schema:url", "@type": "@id" }
  }
}